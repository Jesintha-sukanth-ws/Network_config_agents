
{
  "Cisco": {
    "NX-OS": {
      "preferred_connection": "nxapi_rest",
      "supported_connections": [
        "nxapi_rest",
        "nxapi_cli",
        "netconf",
        "ssh"
      ],
      "default_port": 443,
      "api_base_path": "/ins",
      "supports_yang": true,
      "supports_rest": true,
      "supports_cli_rpc": true,
      "timeout": 30
    },
    "IOS-XE": {
      "preferred_connection": "restconf",
      "supported_connections": [
        "restconf",
        "netconf",
        "ssh"
      ],
      "default_port": 443,
      "api_base_path": "/restconf/data",
      "supports_yang": true,
      "supports_rest": true,
      "supports_cli_rpc": false,
      "timeout": 30
    }
  }
}